# ============================================================
# VERVIERS DÉPANNAGE — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs
# Ne jamais committer .env.local sur GitHub !
# ============================================================

# --- NEXTAUTH (Auth Microsoft Azure AD) ---
NEXTAUTH_URL=https://app.verviersdepannage.com
NEXTAUTH_SECRET=                        # génère avec: openssl rand -base64 32

# Azure AD — https://portal.azure.com > App registrations
AZURE_AD_CLIENT_ID=                     # Application (client) ID
AZURE_AD_CLIENT_SECRET=                 # Client secret value
AZURE_AD_TENANT_ID=                     # Directory (tenant) ID

# --- SUPABASE ---
# https://supabase.com > ton projet > Settings > API
NEXT_PUBLIC_SUPABASE_URL=               # https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # anon / public key
SUPABASE_SERVICE_ROLE_KEY=              # service_role key (côté serveur uniquement)

# --- ODOO ---
ODOO_URL=                               # https://ton-odoo.com
ODOO_DB=                                # nom de la base de données
ODOO_EMAIL=                             # email admin Odoo
ODOO_API_KEY=                           # clé API Odoo (Settings > Technical > API Keys)

# --- GOOGLE MAPS ---
# https://console.cloud.google.com > APIs & Services > Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=        # activer Places API + Maps JavaScript API

# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL=https://app.verviersdepannage.com
NEXT_PUBLIC_APP_NAME=Verviers Dépannage
NEXT_PUBLIC_COMPANY_VAT=BE0460.759.205
NEXT_PUBLIC_COMPANY_ADDRESS=Lefin 12, 4860 Pepinster, Belgique
